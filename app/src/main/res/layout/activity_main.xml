<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="32dp"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="32sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="6dp"
                android:letterSpacing="0.05" />

        </LinearLayout>

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_tab_container"
            app:tabIndicatorHeight="0dp"
            app:tabSelectedTextColor="@color/text_primary"
            app:tabTextColor="@color/text_secondary"
            app:tabRippleColor="@android:color/transparent"
            app:tabMode="fixed"
            app:tabBackground="@drawable/tab_pill_selector" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- ══════════════════════════════════════════ -->
            <!-- HOME SECTION                              -->
            <!-- ══════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/homeSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- External Mode Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/externalCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/surface"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1.5dp"
                    android:layout_marginBottom="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/mode_external_title"
                                android:textSize="20sp"
                                android:textColor="@color/text_primary"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/externalBadge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/accent"
                                android:letterSpacing="0.1" />
                        </RelativeLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/mode_external_desc"
                            android:textSize="15sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="10dp"
                            android:lineSpacingExtra="4dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Browser Mode Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/browserCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/surface"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1.5dp"
                    android:layout_marginBottom="24dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/mode_browser_title"
                                android:textSize="20sp"
                                android:textColor="@color/text_primary"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/browserBadge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary"
                                android:letterSpacing="0.1" />
                        </RelativeLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/mode_browser_desc"
                            android:textSize="15sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="10dp"
                            android:lineSpacingExtra="4dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ─────────────────────────────────────── -->
                <!-- DM PICKER SECTION (visible in External) -->
                <!-- ─────────────────────────────────────── -->
                <LinearLayout
                    android:id="@+id/dmSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/section_dm"
                        android:textSize="18sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/select_dm_desc"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="16dp"
                        android:lineSpacingExtra="2dp" />

                    <!-- DM cards dynamically injected by MainActivity -->
                    <LinearLayout
                        android:id="@+id/dmListContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>

            </LinearLayout>

            <!-- ══════════════════════════════════════════ -->
            <!-- HISTORY SECTION                           -->
            <!-- ══════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/historySection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="gone">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tab_history"
                        android:textSize="18sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:layout_centerVertical="true" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/historyClear"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="@string/history_clear"
                        android:textColor="@color/error"
                        android:textSize="13sp"
                        android:textAllCaps="false"
                        app:iconTint="@color/error" />

                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/historyListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

        </FrameLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>